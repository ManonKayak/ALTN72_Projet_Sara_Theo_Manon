<configuration>
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>
    <logger name="org.example.altn72_projet_sara_theo_manon.errors" level="ERROR"/>
    <root level="WARN">
        <appender-ref ref="STDOUT"/>
    </root>
</configuration>
